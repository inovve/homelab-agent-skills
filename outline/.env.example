# Copy this file to ~/.config/outline/.env  (Windows: %USERPROFILE%\.config\outline\.env)
# and fill in your own values. Never commit the real file.

# Your Outline instance URL (cloud: https://app.getoutline.com, or your self-hosted domain)
OUTLINE_URL=https://app.getoutline.com

# Create under Settings -> API Keys in Outline
OUTLINE_API_KEY=ol_api_your_key_here
